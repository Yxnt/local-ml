# 环境变量配置示例
# 复制此文件为 .env 并填入真实值

# ====== iCloud (日历) ======
ICLOUD_USERNAME=your@apple.id
ICLOUD_PASSWORD=app-specific-password

# ====== Gmail ======
GMAIL_USERNAME=your@gmail.com
GMAIL_APP_PASSWORD=app-specific-password

# ====== Outlook (可选) ======
# OUTLOOK_USERNAME=your@outlook.com
# OUTLOOK_PASSWORD=your-password

# ====== Google Calendar (可选) ======
# GOOGLE_USERNAME=your@gmail.com
# GOOGLE_PASSWORD=app-specific-password

# ====== DSPy 优化 (可选) ======
# OPENAI_API_KEY=sk-...
